{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "kamino-klend-mainnet",
  "label": "Kamino Klend Mainnet",
  "apps": {
    "view_position": {
      "title": "View Position",
      "description": "Read reserve and wallet position details.",
      "entry_step": "view",
      "steps": [
        {
          "id": "view",
          "operation": "view_position",
          "title": "View",
          "description": "Read the current position snapshot.",
          "actions": [
            {
              "label": "Refresh Position",
              "do": {
                "fn": "run",
                "mode": "view"
              }
            }
          ],
          "status_text": {
            "running": "Loading position...",
            "success": "Position loaded.",
            "error": "Position read failed: {error}"
          },
          "label": "View",
          "requires_paths": []
        }
      ],
      "label": "View Position"
    },
    "deposit_liquidity": {
      "title": "Deposit Liquidity",
      "description": "Deposit liquidity into a Kamino reserve.",
      "entry_step": "deposit",
      "steps": [
        {
          "id": "deposit",
          "operation": "deposit_reserve_liquidity",
          "title": "Deposit",
          "description": "Simulate first, then send deposit.",
          "actions": [
            {
              "label": "Simulate Deposit",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Deposit",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing deposit...",
            "success": "Deposit completed.",
            "error": "Deposit failed: {error}"
          },
          "label": "Deposit",
          "requires_paths": []
        }
      ],
      "label": "Deposit Liquidity"
    },
    "withdraw_liquidity": {
      "title": "Withdraw Liquidity",
      "description": "Redeem reserve collateral back to liquidity.",
      "entry_step": "withdraw",
      "steps": [
        {
          "id": "withdraw",
          "operation": "redeem_reserve_collateral",
          "title": "Withdraw",
          "description": "Simulate first, then send withdrawal.",
          "actions": [
            {
              "label": "Simulate Withdraw",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Withdraw",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing withdrawal...",
            "success": "Withdrawal completed.",
            "error": "Withdrawal failed: {error}"
          },
          "label": "Withdraw",
          "requires_paths": []
        }
      ],
      "label": "Withdraw Liquidity"
    }
  }
}
