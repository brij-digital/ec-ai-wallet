{
  "$schema": "/idl/declarative_decoder_runtime.schema.v1.json",
  "schema": "declarative-decoder-runtime.v1",
  "version": "0.1.0",
  "protocolId": "token-index-mainnet",
  "label": "Manual Token Index",
  "programId": "11111111111111111111111111111111",
  "decoderArtifacts": {
    "default": {
      "kind": "generated_idl_decoder",
      "family": "codama",
      "artifact": "token_index",
      "codamaPath": "/idl/token_index.codama.json"
    }
  },
  "sources": {},
  "matchRules": [],
  "pipelines": {},
  "projectionSpecs": {},
  "operations": {
    "tokens_get": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "filters": {
            "field": "symbol",
            "op": "ieq",
            "value": "$input.symbol"
          },
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        }
      }
    },
    "tokens_index": {
      "index_view": {
        "kind": "search",
        "canonical": {
          "source": "indexed_idl_state",
          "protocol_id": "token-index-mainnet",
          "record_kind": "account",
          "record_name": "Token",
          "notes": "Manual token directory seeded directly into canonical state."
        },
        "projection": {
          "projection_kind": "search",
          "sort_by": [
            {
              "field": "symbol",
              "dir": "asc"
            }
          ]
        }
      }
    }
  }
}
