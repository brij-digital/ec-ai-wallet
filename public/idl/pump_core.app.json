{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "pump-core-mainnet",
  "label": "Pump Core Mainnet",
  "templates": {},
  "operations": {
    "buy_exact_sol_in": {
      "label": "Buy Exact Sol In",
      "inputs": {
        "base_mint": {
          "label": "Token",
          "placeholder": "Token mint address",
          "help": "Enter the token you want to buy.",
          "group": "market",
          "display_order": 1
        },
        "spendable_sol_in": {
          "label": "Amount in SOL",
          "placeholder": "0.01",
          "help": "How much SOL to spend.",
          "group": "trade",
          "display_order": 2
        },
        "slippage_bps": {
          "label": "Slippage",
          "placeholder": "1.00",
          "help": "Max price movement you accept, in percent.",
          "group": "trade",
          "display_order": 3
        },
        "min_tokens_out": {
          "label": "Minimum tokens received",
          "help": "Calculated automatically.",
          "group": "trade",
          "display_order": 4,
          "ui_mode": "readonly"
        },
        "track_volume": {
          "label": "Track Volume",
          "ui_mode": "hidden"
        }
      }
    }
  },
  "apps": {
    "buy_curve_token": {
      "title": "Buy Token (Pump Curve)",
      "description": "Buy non-graduated token on Pump bonding curve.",
      "entry_step": "buy",
      "steps": [
        {
          "id": "buy",
          "operation": "buy_exact_sol_in",
          "title": "Buy",
          "description": "Simulate first, then send with the same inputs.",
          "actions": [
            {
              "label": "Simulate Buy",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Buy",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing buy on bonding curve...",
            "success": "Buy step completed.",
            "error": "Buy failed: {error}"
          },
          "label": "Buy",
          "requires_paths": []
        }
      ],
      "label": "Buy Token (Pump Curve)"
    }
  }
}
