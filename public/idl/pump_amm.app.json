{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "pump-amm-mainnet",
  "label": "Pump Amm Mainnet",
  "sources": {
    "pump_swap_crawler": {
      "kind": "rpc_transaction_crawler",
      "programId": "$protocol.programId",
      "decoderFamily": "anchor_events",
      "decoder": "pump_swap",
      "commitment": "confirmed",
      "filters": {},
      "handlers": {
        "CreatePoolEvent": {
          "action": "emit_state",
          "resolve": [
            {
              "name": "baseSupply",
              "resolve": "rpc.token_supply",
              "mint": "$ctx.mint"
            }
          ],
          "emit": {
            "state": {
              "recordName": "PoolMetadata",
              "payload": {
                "pool": "$ctx.pool",
                "mint": "$ctx.mint",
                "quoteMint": "$ctx.quoteMint",
                "baseDecimals": "$ctx.baseDecimals",
                "quoteDecimals": "$ctx.quoteDecimals",
                "baseSupplyUi": "$baseSupply.supplyUi",
                "coinCreator": "$ctx.coinCreator",
                "isCashbackCoin": "$ctx.isCashbackCoin"
              }
            }
          }
        },
        "BuyEvent": {
          "action": "emit_record_and_state",
          "side": "buy",
          "compute": [
            {
              "name": "baseAmountUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.baseAmountAtomic",
              "decimals": "$ctx.baseDecimals"
            },
            {
              "name": "quoteAmountUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.quoteAmountAtomic",
              "decimals": "$ctx.quoteDecimals"
            },
            {
              "name": "priceQuote",
              "compute": "math.safe_div",
              "dividend": "$quoteAmountUi",
              "divisor": "$baseAmountUi"
            },
            {
              "name": "supplyPositive",
              "compute": "compare.gt",
              "left": "$ctx.baseSupplyUi",
              "right": 0
            },
            {
              "name": "marketCapRaw",
              "compute": "math.mul",
              "values": [
                "$priceQuote",
                "$ctx.baseSupplyUi"
              ]
            },
            {
              "name": "marketCapQuote",
              "compute": "logic.if",
              "condition": "$supplyPositive",
              "then": "$marketCapRaw",
              "else": "$null"
            },
            {
              "name": "baseReserveUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.poolBaseReservesAtomic",
              "decimals": "$ctx.baseDecimals"
            },
            {
              "name": "quoteReserveUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.poolQuoteReservesAtomic",
              "decimals": "$ctx.quoteDecimals"
            },
            {
              "name": "baseReserveQuoteValue",
              "compute": "math.mul",
              "values": [
                "$baseReserveUi",
                "$priceQuote"
              ]
            },
            {
              "name": "liquidityQuote",
              "compute": "math.add",
              "values": [
                "$baseReserveQuoteValue",
                "$quoteReserveUi"
              ]
            }
          ],
          "emit": {
            "record": {
              "recordName": "BuyEvent",
              "payload": {
                "mint": "$ctx.mint",
                "pool": "$ctx.pool",
                "marketType": "$ctx.marketType",
                "participant": "$ctx.participant",
                "side": "$ctx.side",
                "priceQuote": "$ctx.priceQuote",
                "marketCapQuote": "$ctx.marketCapQuote",
                "quoteAmountUi": "$ctx.quoteAmountUi",
                "baseAmountAtomic": "$ctx.baseAmountAtomic",
                "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
                "signature": "$ctx.signature",
                "slot": "$ctx.slot",
                "observedAt": "$ctx.observedAt"
              }
            },
            "state": {
              "recordName": "Pool",
              "payload": {
                "mint": "$ctx.mint",
                "pool": "$ctx.pool",
                "marketType": "$ctx.marketType",
                "quoteMint": "$ctx.quoteMint",
                "baseDecimals": "$ctx.baseDecimals",
                "quoteDecimals": "$ctx.quoteDecimals",
                "priceQuote": "$ctx.priceQuote",
                "marketCapQuote": "$ctx.marketCapQuote",
                "liquidityQuote": "$ctx.liquidityQuote",
                "baseReserveUi": "$ctx.baseReserveUi",
                "quoteReserveUi": "$ctx.quoteReserveUi",
                "baseSupplyUi": "$ctx.baseSupplyUi",
                "coinCreator": "$ctx.coinCreator",
                "isCashbackCoin": "$ctx.isCashbackCoin",
                "observedAt": "$ctx.observedAt"
              }
            }
          }
        },
        "SellEvent": {
          "action": "emit_record_and_state",
          "side": "sell",
          "compute": [
            {
              "name": "baseAmountUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.baseAmountAtomic",
              "decimals": "$ctx.baseDecimals"
            },
            {
              "name": "quoteAmountUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.quoteAmountAtomic",
              "decimals": "$ctx.quoteDecimals"
            },
            {
              "name": "priceQuote",
              "compute": "math.safe_div",
              "dividend": "$quoteAmountUi",
              "divisor": "$baseAmountUi"
            },
            {
              "name": "supplyPositive",
              "compute": "compare.gt",
              "left": "$ctx.baseSupplyUi",
              "right": 0
            },
            {
              "name": "marketCapRaw",
              "compute": "math.mul",
              "values": [
                "$priceQuote",
                "$ctx.baseSupplyUi"
              ]
            },
            {
              "name": "marketCapQuote",
              "compute": "logic.if",
              "condition": "$supplyPositive",
              "then": "$marketCapRaw",
              "else": "$null"
            },
            {
              "name": "baseReserveUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.poolBaseReservesAtomic",
              "decimals": "$ctx.baseDecimals"
            },
            {
              "name": "quoteReserveUi",
              "compute": "math.amount_ui",
              "amount": "$ctx.poolQuoteReservesAtomic",
              "decimals": "$ctx.quoteDecimals"
            },
            {
              "name": "baseReserveQuoteValue",
              "compute": "math.mul",
              "values": [
                "$baseReserveUi",
                "$priceQuote"
              ]
            },
            {
              "name": "liquidityQuote",
              "compute": "math.add",
              "values": [
                "$baseReserveQuoteValue",
                "$quoteReserveUi"
              ]
            }
          ],
          "emit": {
            "record": {
              "recordName": "SellEvent",
              "payload": {
                "mint": "$ctx.mint",
                "pool": "$ctx.pool",
                "marketType": "$ctx.marketType",
                "participant": "$ctx.participant",
                "side": "$ctx.side",
                "priceQuote": "$ctx.priceQuote",
                "marketCapQuote": "$ctx.marketCapQuote",
                "quoteAmountUi": "$ctx.quoteAmountUi",
                "baseAmountAtomic": "$ctx.baseAmountAtomic",
                "quoteAmountAtomic": "$ctx.quoteAmountAtomic",
                "signature": "$ctx.signature",
                "slot": "$ctx.slot",
                "observedAt": "$ctx.observedAt"
              }
            },
            "state": {
              "recordName": "Pool",
              "payload": {
                "mint": "$ctx.mint",
                "pool": "$ctx.pool",
                "marketType": "$ctx.marketType",
                "quoteMint": "$ctx.quoteMint",
                "baseDecimals": "$ctx.baseDecimals",
                "quoteDecimals": "$ctx.quoteDecimals",
                "priceQuote": "$ctx.priceQuote",
                "marketCapQuote": "$ctx.marketCapQuote",
                "liquidityQuote": "$ctx.liquidityQuote",
                "baseReserveUi": "$ctx.baseReserveUi",
                "quoteReserveUi": "$ctx.quoteReserveUi",
                "baseSupplyUi": "$ctx.baseSupplyUi",
                "coinCreator": "$ctx.coinCreator",
                "isCashbackCoin": "$ctx.isCashbackCoin",
                "observedAt": "$ctx.observedAt"
              }
            }
          }
        }
      }
    }
  },
  "templates": {
    "pump.buy.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "quote_amount_in": {
          "type": "u64"
        },
        "slippage_bps": {
          "type": "u16"
        },
        "track_volume": {
          "type": "bool"
        }
      },
      "expand": {
        "instruction": "buy",
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": false,
            "commitment": "confirmed",
            "account_pubkeys": "$input.pool",
            "filters": [
              {
                "memcmp": {
                  "offset": 43,
                  "bytesFrom": "$param.base_mint"
                }
              },
              {
                "memcmp": {
                  "offset": 75,
                  "bytesFrom": "$param.quote_mint"
                }
              }
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 10,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator"
            }
          },
          {
            "name": "selected_pool",
            "discover": "discover.pick_list_item_by_value",
            "items": "$pool_candidates",
            "value_path": "pool",
            "match_value": "$input.pool"
          }
        ],
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$selected_pool.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "global_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_volume_accumulator"
            ]
          },
          {
            "name": "user_volume_accumulator",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:user_volume_accumulator",
              "$wallet"
            ]
          },
          {
            "name": "user_volume_accumulator_wsol_ata",
            "resolver": "ata",
            "owner": "$user_volume_accumulator",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          },
          {
            "name": "fee_config_data",
            "resolver": "decode_account",
            "address": "$fee_config",
            "account_type": "FeeConfig"
          },
          {
            "name": "pump_pool_authority",
            "resolver": "pda",
            "program_id": "6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P",
            "seeds": [
              "utf8:pool-authority",
              "$pool_data.base_mint"
            ]
          },
          {
            "name": "pool_base_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_base_token_account"
          },
          {
            "name": "pool_quote_reserve_atomic",
            "resolver": "token_account_balance",
            "address": "$pool_data.pool_quote_token_account"
          },
          {
            "name": "base_mint_supply_atomic",
            "resolver": "token_supply",
            "mint": "$pool_data.base_mint"
          },
          {
            "name": "pool_v2",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:pool-v2",
              "$pool_data.base_mint"
            ]
          }
        ],
        "args": {
          "base_amount_out": "$base_amount_out",
          "max_quote_amount_in": "$max_quote_amount_in",
          "track_volume": "$param.track_volume"
        },
        "pre": [
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$user_base_token_account",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "kind": "spl_ata_create_idempotent",
            "payer": "$wallet",
            "ata": "$user_quote_token_account",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "kind": "system_transfer",
            "from": "$wallet",
            "to": "$user_quote_token_account",
            "lamports": "$max_quote_amount_in",
            "when": {
              "equals": [
                "$pool_data.quote_mint",
                "So11111111111111111111111111111111111111112"
              ]
            }
          },
          {
            "kind": "spl_token_sync_native",
            "account": "$user_quote_token_account",
            "when": {
              "equals": [
                "$pool_data.quote_mint",
                "So11111111111111111111111111111111111111112"
              ]
            }
          }
        ],
        "accounts": {
          "pool": "$selected_pool.pool",
          "user": "$wallet",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "protocol_fee_recipient_token_account": "$protocol_fee_recipient_token_account",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "system_program": "11111111111111111111111111111111",
          "associated_token_program": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
          "event_authority": "$event_authority",
          "program": "$protocol.programId",
          "coin_creator_vault_ata": "$coin_creator_vault_ata",
          "coin_creator_vault_authority": "$coin_creator_vault_authority",
          "global_volume_accumulator": "$global_volume_accumulator",
          "user_volume_accumulator": "$user_volume_accumulator",
          "fee_config": "$fee_config",
          "fee_program": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ"
        },
        "remaining_accounts": "$remaining_accounts",
        "compute": [
          {
            "name": "protocol_fee_recipient",
            "compute": "list.get",
            "values": "$global_config_data.protocol_fee_recipients",
            "index": 0
          },
          {
            "name": "protocol_fee_recipient_token_account",
            "compute": "pda(seed_spec)",
            "program_id": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
            "seeds": [
              {
                "kind": "pubkey",
                "value": "$protocol_fee_recipient"
              },
              {
                "kind": "pubkey",
                "value": "$quote_token_program"
              },
              {
                "kind": "pubkey",
                "value": "$pool_data.quote_mint"
              }
            ]
          },
          {
            "name": "remaining_accounts",
            "compute": "logic.if",
            "condition": "$pool_data.is_cashback_coin",
            "then": [
              {
                "pubkey": "$user_volume_accumulator_wsol_ata",
                "isSigner": false,
                "isWritable": true
              },
              {
                "pubkey": "$pool_v2",
                "isSigner": false,
                "isWritable": false
              }
            ],
            "else": [
              {
                "pubkey": "$pool_v2",
                "isSigner": false,
                "isWritable": false
              }
            ]
          },
          {
            "name": "creator_is_default",
            "compute": "compare.equals",
            "left": "$pool_data.coin_creator",
            "right": "11111111111111111111111111111111"
          },
          {
            "name": "is_pump_pool",
            "compute": "compare.equals",
            "left": "$pool_data.creator",
            "right": "$pump_pool_authority"
          },
          {
            "name": "market_cap_numerator",
            "compute": "math.mul",
            "values": [
              "$pool_quote_reserve_atomic",
              "$base_mint_supply_atomic"
            ]
          },
          {
            "name": "market_cap_lamports",
            "compute": "math.floor_div",
            "dividend": "$market_cap_numerator",
            "divisor": "$pool_base_reserve_atomic"
          },
          {
            "name": "fee_tier_candidates",
            "compute": "list.filter",
            "items": "$fee_config_data.fee_tiers",
            "where": [
              {
                "path": "market_cap_lamports_threshold",
                "op": ">=",
                "value": "$market_cap_lamports"
              }
            ]
          },
          {
            "name": "selected_fee_tier_primary",
            "compute": "list.min_by",
            "items": "$fee_tier_candidates",
            "path": "market_cap_lamports_threshold",
            "allow_empty": true
          },
          {
            "name": "selected_fee_tier_default",
            "compute": "list.max_by",
            "items": "$fee_config_data.fee_tiers",
            "path": "market_cap_lamports_threshold",
            "allow_empty": true
          },
          {
            "name": "selected_fee_tier",
            "compute": "coalesce",
            "values": [
              "$selected_fee_tier_primary",
              "$selected_fee_tier_default"
            ]
          },
          {
            "name": "selected_fees_if_pump",
            "compute": "coalesce",
            "values": [
              "$selected_fee_tier.fees",
              "$fee_config_data.flat_fees"
            ]
          },
          {
            "name": "lp_fee_bps",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.lp_fee_bps",
            "else": "$global_config_data.lp_fee_basis_points"
          },
          {
            "name": "protocol_fee_bps",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.protocol_fee_bps",
            "else": "$global_config_data.protocol_fee_basis_points"
          },
          {
            "name": "creator_fee_bps_raw",
            "compute": "logic.if",
            "condition": "$is_pump_pool",
            "then": "$selected_fees_if_pump.creator_fee_bps",
            "else": "$global_config_data.coin_creator_fee_basis_points"
          },
          {
            "name": "creator_fee_bps",
            "compute": "logic.if",
            "condition": "$creator_is_default",
            "then": "0",
            "else": "$creator_fee_bps_raw"
          },
          {
            "name": "total_fee_bps",
            "compute": "math.add",
            "values": [
              "$lp_fee_bps",
              "$protocol_fee_bps",
              "$creator_fee_bps"
            ]
          },
          {
            "name": "effective_quote_numerator",
            "compute": "math.mul",
            "values": [
              "$param.quote_amount_in",
              "10000"
            ]
          },
          {
            "name": "effective_quote_denominator",
            "compute": "math.add",
            "values": [
              "10000",
              "$total_fee_bps"
            ]
          },
          {
            "name": "effective_quote",
            "compute": "math.floor_div",
            "dividend": "$effective_quote_numerator",
            "divisor": "$effective_quote_denominator"
          },
          {
            "name": "base_amount_out_numerator",
            "compute": "math.mul",
            "values": [
              "$pool_base_reserve_atomic",
              "$effective_quote"
            ]
          },
          {
            "name": "base_amount_out_denominator",
            "compute": "math.add",
            "values": [
              "$pool_quote_reserve_atomic",
              "$effective_quote"
            ]
          },
          {
            "name": "base_amount_out",
            "compute": "math.floor_div",
            "dividend": "$base_amount_out_numerator",
            "divisor": "$base_amount_out_denominator"
          },
          {
            "name": "slippage_factor",
            "compute": "math.add",
            "values": [
              "10000",
              "$param.slippage_bps"
            ]
          },
          {
            "name": "max_quote_amount_in_numerator",
            "compute": "math.mul",
            "values": [
              "$param.quote_amount_in",
              "$slippage_factor"
            ]
          },
          {
            "name": "max_quote_amount_in",
            "compute": "math.floor_div",
            "dividend": "$max_quote_amount_in_numerator",
            "divisor": "10000"
          }
        ]
      }
    },
    "pump.list_tokens.v1": {
      "params": {
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        }
      },
      "expand": {
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": true,
            "commitment": "confirmed",
            "where": [
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.index",
                "dir": "desc"
              },
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 30,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "index": "$decoded.index",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator",
              "isCashbackCoin": "$decoded.is_cashback_coin"
            },
            "or_filters": [
              [
                {
                  "memcmp": {
                    "offset": 75,
                    "bytesFrom": "$param.quote_mint"
                  }
                }
              ]
            ]
          }
        ]
      }
    },
    "pump.view_pool.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey",
          "required": false,
          "default": "So11111111111111111111111111111111111111112"
        }
      },
      "expand": {
        "discover": [
          {
            "name": "pool_detail",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": true,
            "commitment": "confirmed",
            "or_filters": [
              [
                {
                  "memcmp": {
                    "offset": 43,
                    "bytesFrom": "$param.base_mint"
                  }
                },
                {
                  "memcmp": {
                    "offset": 75,
                    "bytesFrom": "$param.quote_mint"
                  }
                }
              ]
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.index",
                "dir": "desc"
              },
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 1,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "index": "$decoded.index",
              "lpSupply": "$decoded.lp_supply",
              "poolBaseTokenAccount": "$decoded.pool_base_token_account",
              "poolQuoteTokenAccount": "$decoded.pool_quote_token_account",
              "coinCreator": "$decoded.coin_creator",
              "isCashbackCoin": "$decoded.is_cashback_coin"
            }
          }
        ]
      }
    },
    "pump.sell.v1": {
      "params": {
        "base_mint": {
          "type": "pubkey"
        },
        "quote_mint": {
          "type": "pubkey"
        },
        "base_amount_in": {
          "type": "u64"
        },
        "min_quote_amount_out": {
          "type": "u64"
        }
      },
      "expand": {
        "instruction": "sell",
        "discover": [
          {
            "name": "pool_candidates",
            "discover": "discover.query",
            "source": "rpc.getProgramAccounts",
            "program_id": "$protocol.programId",
            "account_type": "Pool",
            "discriminator_filter": false,
            "commitment": "confirmed",
            "account_pubkeys": "$input.pool",
            "filters": [
              {
                "memcmp": {
                  "offset": 43,
                  "bytesFrom": "$param.base_mint"
                }
              },
              {
                "memcmp": {
                  "offset": 75,
                  "bytesFrom": "$param.quote_mint"
                }
              }
            ],
            "where": [
              {
                "path": "decoded.base_mint",
                "op": "=",
                "value": "$param.base_mint"
              },
              {
                "path": "decoded.quote_mint",
                "op": "=",
                "value": "$param.quote_mint"
              },
              {
                "path": "decoded.lp_supply",
                "op": ">",
                "value": "0"
              }
            ],
            "sort": [
              {
                "path": "decoded.lp_supply",
                "dir": "desc"
              }
            ],
            "limit": 10,
            "select": {
              "pool": "$account.pubkey",
              "baseMint": "$decoded.base_mint",
              "quoteMint": "$decoded.quote_mint",
              "lpSupply": "$decoded.lp_supply",
              "coinCreator": "$decoded.coin_creator"
            }
          },
          {
            "name": "selected_pool",
            "discover": "discover.pick_list_item_by_value",
            "items": "$pool_candidates",
            "value_path": "pool",
            "match_value": "$input.pool"
          }
        ],
        "derive": [
          {
            "name": "wallet",
            "resolver": "wallet_pubkey"
          },
          {
            "name": "pool_data",
            "resolver": "decode_account",
            "address": "$selected_pool.pool",
            "account_type": "Pool"
          },
          {
            "name": "global_config",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:global_config"
            ]
          },
          {
            "name": "global_config_data",
            "resolver": "decode_account",
            "address": "$global_config",
            "account_type": "GlobalConfig"
          },
          {
            "name": "base_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.base_mint"
          },
          {
            "name": "quote_token_program",
            "resolver": "account_owner",
            "address": "$pool_data.quote_mint"
          },
          {
            "name": "user_base_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.base_mint",
            "token_program": "$base_token_program"
          },
          {
            "name": "user_quote_token_account",
            "resolver": "ata",
            "owner": "$wallet",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program"
          },
          {
            "name": "coin_creator_vault_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:creator_vault",
              "$pool_data.coin_creator"
            ]
          },
          {
            "name": "coin_creator_vault_ata",
            "resolver": "ata",
            "owner": "$coin_creator_vault_authority",
            "mint": "$pool_data.quote_mint",
            "token_program": "$quote_token_program",
            "allow_owner_off_curve": true
          },
          {
            "name": "event_authority",
            "resolver": "pda",
            "program_id": "$protocol.programId",
            "seeds": [
              "utf8:__event_authority"
            ]
          },
          {
            "name": "fee_config",
            "resolver": "pda",
            "program_id": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ",
            "seeds": [
              "utf8:fee_config",
              "$protocol.programId"
            ]
          }
        ],
        "args": {
          "base_amount_in": "$param.base_amount_in",
          "min_quote_amount_out": "$param.min_quote_amount_out"
        },
        "accounts": {
          "pool": "$selected_pool.pool",
          "user": "$wallet",
          "global_config": "$global_config",
          "base_mint": "$pool_data.base_mint",
          "quote_mint": "$pool_data.quote_mint",
          "user_base_token_account": "$user_base_token_account",
          "user_quote_token_account": "$user_quote_token_account",
          "pool_base_token_account": "$pool_data.pool_base_token_account",
          "pool_quote_token_account": "$pool_data.pool_quote_token_account",
          "protocol_fee_recipient": "$protocol_fee_recipient",
          "protocol_fee_recipient_token_account": "$protocol_fee_recipient_token_account",
          "base_token_program": "$base_token_program",
          "quote_token_program": "$quote_token_program",
          "system_program": "11111111111111111111111111111111",
          "associated_token_program": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
          "event_authority": "$event_authority",
          "program": "$protocol.programId",
          "coin_creator_vault_ata": "$coin_creator_vault_ata",
          "coin_creator_vault_authority": "$coin_creator_vault_authority",
          "fee_config": "$fee_config",
          "fee_program": "pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ"
        },
        "compute": [
          {
            "name": "protocol_fee_recipient",
            "compute": "list.get",
            "values": "$global_config_data.protocol_fee_recipients",
            "index": 0
          },
          {
            "name": "protocol_fee_recipient_token_account",
            "compute": "pda(seed_spec)",
            "program_id": "ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL",
            "seeds": [
              {
                "kind": "pubkey",
                "value": "$protocol_fee_recipient"
              },
              {
                "kind": "pubkey",
                "value": "$quote_token_program"
              },
              {
                "kind": "pubkey",
                "value": "$pool_data.quote_mint"
              }
            ]
          }
        ]
      }
    }
  },
