{
  "$schema": "/idl/meta_app.schema.v0.1.json",
  "schema": "meta-app.v0.1",
  "version": "0.2.0",
  "protocolId": "pump-amm-mainnet",
  "label": "Pump Amm Mainnet",
  "apps": {
    "token_terminal": {
      "title": "Pump Token Terminal",
      "description": "Step 1: list tokens. Step 2: pool snapshot. Step 3/4: buy or sell.",
      "entry_step": "discover",
      "steps": [
        {
          "id": "discover",
          "label": "List Tokens",
          "operation": "list_tokens",
          "title": "List Tokens",
          "description": "Discover Pump AMM tokens from quote mint and choose one token/pool.",
          "actions": [
            {
              "label": "Find Tokens",
              "do": {
                "fn": "run",
                "mode": "view"
              }
            }
          ],
          "next_on_success": "pool",
          "status_text": {
            "running": "Searching Pump AMM pools...",
            "success": "Token selected. Next: {next_step_title}.",
            "error": "Discovery failed: {error}"
          },
          "ui": {
            "kind": "select_from_derived",
            "source": "pool_candidates",
            "bind_to": "selected_pool",
            "value_path": "pool",
            "label_fields": [
              "baseMint",
              "pool",
              "index",
              "lpSupply"
            ],
            "require_selection": true,
            "auto_advance": true,
            "title": "Select a token/pool",
            "description": "Pick one discovered token to open its pool details and trading actions."
          },
          "requires_paths": []
        },
        {
          "id": "pool",
          "label": "Pool Snapshot",
          "operation": "view_pool",
          "title": "Pool Snapshot",
          "description": "Live pool snapshot from RPC before taking action.",
          "actions": [
            {
              "label": "Back to Tokens",
              "do": {
                "fn": "back"
              }
            },
            {
              "label": "Refresh Snapshot",
              "do": {
                "fn": "run",
                "mode": "view"
              }
            }
          ],
          "status_text": {
            "running": "Loading pool snapshot...",
            "success": "Snapshot refreshed. Continue with Buy or Sell.",
            "error": "Pool snapshot failed: {error}"
          },
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint"
          },
          "requires_paths": [
            "$steps.discover.derived.selected_pool.pool"
          ]
        },
        {
          "id": "buy",
          "label": "Buy",
          "operation": "buy",
          "title": "Buy",
          "description": "Simulate then send buy transaction.",
          "actions": [
            {
              "label": "Back to Snapshot",
              "do": {
                "fn": "back"
              }
            },
            {
              "label": "Simulate Buy",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Buy",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing buy...",
            "success": "Buy step completed.",
            "error": "Buy failed: {error}"
          },
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint",
            "pool": "$steps.discover.derived.selected_pool.pool"
          },
          "requires_paths": [
            "$steps.discover.derived.selected_pool.pool"
          ]
        },
        {
          "id": "sell",
          "label": "Sell",
          "operation": "sell",
          "title": "Sell",
          "description": "Simulate then send sell transaction.",
          "actions": [
            {
              "label": "Back to Snapshot",
              "do": {
                "fn": "back"
              }
            },
            {
              "label": "Simulate Sell",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Sell",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing sell...",
            "success": "Sell step completed.",
            "error": "Sell failed: {error}"
          },
          "input_from": {
            "base_mint": "$steps.discover.derived.selected_pool.baseMint",
            "quote_mint": "$steps.discover.derived.selected_pool.quoteMint",
            "pool": "$steps.discover.derived.selected_pool.pool"
          },
          "requires_paths": [
            "$steps.discover.derived.selected_pool.pool"
          ]
        }
      ],
      "label": "Pump Token Terminal"
    },
    "buy_token": {
      "title": "Buy Token (Pump AMM)",
      "description": "Buy a graduated token directly on Pump AMM.",
      "entry_step": "buy",
      "steps": [
        {
          "id": "buy",
          "label": "Buy",
          "operation": "buy",
          "title": "Buy",
          "description": "Simulate first, then send with the same inputs.",
          "actions": [
            {
              "label": "Simulate Buy",
              "do": {
                "fn": "run",
                "mode": "simulate"
              }
            },
            {
              "label": "Send Buy",
              "do": {
                "fn": "run",
                "mode": "send"
              }
            }
          ],
          "status_text": {
            "running": "Executing buy...",
            "success": "Buy step completed.",
            "error": "Buy failed: {error}"
          },
          "requires_paths": []
        }
      ],
      "label": "Buy Token (Pump AMM)"
    }
  }
}
