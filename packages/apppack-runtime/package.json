{
  "name": "@agentform/apppack-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./idlDeclarativeRuntime": {
      "types": "./dist/idlDeclarativeRuntime.d.ts",
      "import": "./dist/idlDeclarativeRuntime.js"
    },
    "./metaIdlRuntime": {
      "types": "./dist/metaIdlRuntime.d.ts",
      "import": "./dist/metaIdlRuntime.js"
    },
    "./idlRegistry": {
      "types": "./dist/idlRegistry.d.ts",
      "import": "./dist/idlRegistry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@noble/hashes": "^1.8.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3"
  }
}
